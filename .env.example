# Xenia Shot Controller — environment variables
# Copy to .env and fill in your values.
# These override anything in data/config.json.

# Xenia machine local IP
XENIA_HOST=http://192.168.x.x

# LLM provider (Anthropic, OpenAI, Ollama, OpenRouter, …)
# Leave blank to disable AI coaching.
XENIA_LLM_BASE_URL=https://api.anthropic.com
XENIA_LLM_API_KEY=
XENIA_LLM_MODEL=claude-sonnet-4-5
